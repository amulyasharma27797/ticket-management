# PostgreSQL
POSTGRES_USER=ticket_user
POSTGRES_PASSWORD=change_me
POSTGRES_DB=ticket_db

# Backend
DATABASE_URL=postgresql+psycopg2://ticket_user:change_me@postgres:5432/ticket_db
SECRET_KEY=generate_a_long_random_string
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:5173
SEED_USERS=true
SEED_USER_PASSWORD=change_me

# Frontend
VITE_API_URL=http://localhost:8000/api/v1

# Host ports (change if 8000/5173 already in use — then update VITE_API_URL and CORS_ORIGINS to match)
BACKEND_PORT=8000
FRONTEND_PORT=5173

