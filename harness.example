#!/usr/bin/env bash
# harness — local dev orchestrator for the ticket-management monorepo
#
# Setup (one-time):
#   cp harness.example harness && chmod +x harness
#   cp harness.config.example harness.config
#
# Usage:
#   ./harness up              Start BE + FE (default preset: local)
#   ./harness down            Stop all managed processes
#   ./harness restart         Restart BE + FE
#   ./harness rebuild         Reinstall deps and restart
#   ./harness smoke           Run health/smoke checks
#   ./harness status          Show running services
#   ./harness fe <cmd>        Frontend lifecycle (start|stop|restart|install|logs)
#   ./harness be <cmd>        Backend lifecycle (start|stop|restart|install|logs)
#   ./harness preset <name>   Switch preset (local|docker|hybrid)

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
STATE_DIR="${ROOT_DIR}/.harness"
PID_DIR="${STATE_DIR}/pids"
LOG_DIR="${STATE_DIR}/logs"
CONFIG_FILE="${ROOT_DIR}/harness.config"

BE_DIR="${ROOT_DIR}/apps/backend"
FE_DIR="${ROOT_DIR}/apps/frontend"
VENV_DIR="${BE_DIR}/.venv"

# Defaults (overridden by harness.config)
PRESET="${HARNESS_PRESET:-local}"
BE_HOST="${BE_HOST:-0.0.0.0}"
BE_PORT="${BE_PORT:-8000}"
FE_HOST="${FE_HOST:-0.0.0.0}"
FE_PORT="${FE_PORT:-5173}"
BE_HEALTH_URL="${BE_HEALTH_URL:-http://localhost:${BE_PORT}/api/v1/health}"
BE_READY_URL="${BE_READY_URL:-http://localhost:${BE_PORT}/api/v1/health/ready}"
FE_URL="${FE_URL:-http://localhost:${FE_PORT}}"
SMOKE_TIMEOUT="${SMOKE_TIMEOUT:-60}"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

log()  { printf '\033[1;34m[harness]\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m[harness]\033[0m %s\n' "$*"; }
err()  { printf '\033[1;31m[harness]\033[0m %s\n' "$*" >&2; }

die() { err "$@"; exit 1; }

load_config() {
  if [[ -f "${CONFIG_FILE}" ]]; then
  # shellcheck source=/dev/null
    source "${CONFIG_FILE}"
  else
    warn "No harness.config found — using defaults. Run: cp harness.config.example harness.config"
  fi
}

ensure_state_dirs() {
  mkdir -p "${PID_DIR}" "${LOG_DIR}"
}

pid_file() { echo "${PID_DIR}/$1.pid"; }
log_file() { echo "${LOG_DIR}/$1.log"; }

is_running() {
  local name="$1"
  local pf
  pf="$(pid_file "${name}")"
  if [[ -f "${pf}" ]]; then
    local pid
    pid="$(cat "${pf}")"
    if kill -0 "${pid}" 2>/dev/null; then
      return 0
    fi
    rm -f "${pf}"
  fi
  return 1
}

stop_process() {
  local name="$1"
  local pf
  pf="$(pid_file "${name}")"
  if [[ -f "${pf}" ]]; then
    local pid
    pid="$(cat "${pf}")"
    if kill -0 "${pid}" 2>/dev/null; then
      log "Stopping ${name} (pid ${pid})..."
      kill "${pid}" 2>/dev/null || true
      sleep 1
      kill -9 "${pid}" 2>/dev/null || true
    fi
    rm -f "${pf}"
  fi
}

wait_for_url() {
  local url="$1"
  local label="$2"
  local timeout="${3:-${SMOKE_TIMEOUT}}"
  local elapsed=0
  log "Waiting for ${label} at ${url}..."
  while (( elapsed < timeout )); do
    if curl -sf "${url}" >/dev/null 2>&1; then
      log "${label} is up."
      return 0
    fi
    sleep 2
    elapsed=$((elapsed + 2))
  done
  die "${label} did not become ready within ${timeout}s"
}

apply_preset() {
  case "${PRESET}" in
    local)
      export DATABASE_URL="${DATABASE_URL:-postgresql+psycopg2://ticket_user:change_me@localhost:5432/ticket_db}"
      export VITE_API_URL="${VITE_API_URL:-http://localhost:${BE_PORT}/api/v1}"
      ;;
    hybrid)
      export DATABASE_URL="${DATABASE_URL:-postgresql+psycopg2://ticket_user:change_me@localhost:5432/ticket_db}"
      export VITE_API_URL="${VITE_API_URL:-http://localhost:${BE_PORT}/api/v1}"
      ;;
    docker)
      : # docker compose manages env via .env
      ;;
    *)
      die "Unknown preset: ${PRESET}. Use: local, hybrid, or docker"
      ;;
  esac
}

# ---------------------------------------------------------------------------
# Infrastructure
# ---------------------------------------------------------------------------

start_postgres() {
  if [[ "${PRESET}" == "docker" ]]; then
    return 0
  fi
  if [[ -f "${ROOT_DIR}/docker-compose.yml" ]]; then
    log "Starting Postgres (docker compose)..."
    docker compose -f "${ROOT_DIR}/docker-compose.yml" up -d postgres
  else
    warn "docker-compose.yml not found — assuming Postgres is already running on localhost:5432"
  fi
}

stop_postgres() {
  if [[ "${PRESET}" == "docker" ]]; then
    return 0
  fi
  if [[ -f "${ROOT_DIR}/docker-compose.yml" ]]; then
    log "Stopping Postgres..."
    docker compose -f "${ROOT_DIR}/docker-compose.yml" stop postgres 2>/dev/null || true
  fi
}

# ---------------------------------------------------------------------------
# Backend
# ---------------------------------------------------------------------------

be_install() {
  [[ -d "${BE_DIR}" ]] || die "Backend not found at ${BE_DIR}"
  log "Installing backend dependencies..."
  if [[ ! -d "${VENV_DIR}" ]]; then
    python3.12 -m venv "${VENV_DIR}" || python3 -m venv "${VENV_DIR}"
  fi
  # shellcheck source=/dev/null
  source "${VENV_DIR}/bin/activate"
  pip install --upgrade pip -q
  if [[ -f "${BE_DIR}/requirements-dev.txt" ]]; then
    pip install -r "${BE_DIR}/requirements-dev.txt" -q
  elif [[ -f "${BE_DIR}/requirements.txt" ]]; then
    pip install -r "${BE_DIR}/requirements.txt" -q
  else
    die "No requirements.txt found in ${BE_DIR}"
  fi
}

be_start() {
  [[ -d "${BE_DIR}" ]] || die "Backend not found at ${BE_DIR}"
  if is_running be; then
    warn "Backend already running."
    return 0
  fi
  ensure_state_dirs
  be_install
  # shellcheck source=/dev/null
  source "${VENV_DIR}/bin/activate"

  if [[ -f "${ROOT_DIR}/alembic.ini" ]]; then
    log "Running migrations..."
    (cd "${ROOT_DIR}" && alembic -c alembic.ini upgrade head) || warn "Migration step skipped or failed"
  fi

  log "Starting backend on ${BE_HOST}:${BE_PORT}..."
  (
    cd "${BE_DIR}"
    export DATABASE_URL CORS_ORIGINS SECRET_KEY
    exec uvicorn app.main:app --host "${BE_HOST}" --port "${BE_PORT}" --reload
  ) >>"$(log_file be)" 2>&1 &
  echo $! >"$(pid_file be)"
  log "Backend pid $(cat "$(pid_file be)") — logs: $(log_file be)"
}

be_stop()  { stop_process be; }
be_logs()  { tail -f "$(log_file be)" 2>/dev/null || warn "No backend logs yet."; }

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------

fe_install() {
  [[ -d "${FE_DIR}" ]] || die "Frontend not found at ${FE_DIR}"
  log "Installing frontend dependencies..."
  (cd "${FE_DIR}" && npm install)
}

fe_start() {
  [[ -d "${FE_DIR}" ]] || die "Frontend not found at ${FE_DIR}"
  if is_running fe; then
    warn "Frontend already running."
    return 0
  fi
  ensure_state_dirs
  if [[ ! -d "${FE_DIR}/node_modules" ]]; then
    fe_install
  fi
  log "Starting frontend on ${FE_HOST}:${FE_PORT}..."
  (
    cd "${FE_DIR}"
    export VITE_API_URL
    exec npm run dev -- --host "${FE_HOST}" --port "${FE_PORT}"
  ) >>"$(log_file fe)" 2>&1 &
  echo $! >"$(pid_file fe)"
  log "Frontend pid $(cat "$(pid_file fe)") — logs: $(log_file fe)"
}

fe_stop()  { stop_process fe; }
fe_logs()  { tail -f "$(log_file fe)" 2>/dev/null || warn "No frontend logs yet."; }

# ---------------------------------------------------------------------------
# Docker preset
# ---------------------------------------------------------------------------

docker_up() {
  [[ -f "${ROOT_DIR}/docker-compose.yml" ]] || die "docker-compose.yml not found"
  log "Starting full stack via Docker Compose (preset: docker)..."
  docker compose -f "${ROOT_DIR}/docker-compose.yml" up --build -d
}

docker_down() {
  [[ -f "${ROOT_DIR}/docker-compose.yml" ]] || return 0
  log "Stopping Docker Compose stack..."
  docker compose -f "${ROOT_DIR}/docker-compose.yml" down
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

cmd_up() {
  load_config
  apply_preset
  ensure_state_dirs

  case "${PRESET}" in
    docker)
      docker_up
      cmd_smoke
      ;;
    local|hybrid)
      start_postgres
      be_start
      fe_start
      wait_for_url "${BE_HEALTH_URL}" "Backend" 30 || true
      wait_for_url "${FE_URL}" "Frontend" 30 || true
      log "Stack running — FE: ${FE_URL}  BE: http://localhost:${BE_PORT}/api/v1/docs"
      log "Press Ctrl+C or run './harness down' to stop."
      trap 'cmd_down' INT TERM
      tail -f "$(log_file be)" "$(log_file fe)" 2>/dev/null || wait
      ;;
  esac
}

cmd_down() {
  load_config
  case "${PRESET}" in
    docker) docker_down ;;
    *)
      fe_stop
      be_stop
      stop_postgres
      ;;
  esac
  log "Stopped."
}

cmd_restart() {
  cmd_down
  sleep 1
  PRESET="${PRESET}" cmd_up
}

cmd_rebuild() {
  local target="${1:-all}"
  load_config
  apply_preset
  case "${target}" in
    be|backend)
      be_stop
      rm -rf "${VENV_DIR}"
      be_install
      be_start
      ;;
    fe|frontend)
      fe_stop
      rm -rf "${FE_DIR}/node_modules"
      fe_install
      fe_start
      ;;
    all|*)
      cmd_down
      rm -rf "${VENV_DIR}" "${FE_DIR}/node_modules"
      start_postgres
      be_install
      fe_install
      be_start
      fe_start
      ;;
  esac
  log "Rebuild complete."
}

cmd_smoke() {
  load_config
  apply_preset
  log "Running smoke tests..."
  local failed=0

  if curl -sf "${BE_HEALTH_URL}" >/dev/null 2>&1; then
    log "✓ Backend health: ${BE_HEALTH_URL}"
  else
    err "✗ Backend health failed: ${BE_HEALTH_URL}"
    failed=1
  fi

  if curl -sf "${BE_READY_URL}" >/dev/null 2>&1; then
    log "✓ Backend ready:  ${BE_READY_URL}"
  else
    warn "✗ Backend ready check failed (may be expected before Phase 0): ${BE_READY_URL}"
  fi

  if curl -sf "${FE_URL}" >/dev/null 2>&1; then
    log "✓ Frontend:       ${FE_URL}"
  else
    err "✗ Frontend failed: ${FE_URL}"
    failed=1
  fi

  if (( failed > 0 )); then
    die "Smoke tests failed."
  fi
  log "All smoke tests passed."
}

cmd_status() {
  load_config
  printf '\n%-12s %-8s %s\n' "SERVICE" "STATUS" "DETAIL"
  printf '%.0s-' {1..50}; echo

  if is_running be; then
    printf '%-12s %-8s pid %s\n' "backend" "running" "$(cat "$(pid_file be)")"
  else
    printf '%-12s %-8s\n' "backend" "stopped"
  fi

  if is_running fe; then
    printf '%-12s %-8s pid %s\n' "frontend" "running" "$(cat "$(pid_file fe)")"
  else
    printf '%-12s %-8s\n' "frontend" "stopped"
  fi

  printf '\nPreset: %s\n' "${PRESET}"
  printf 'BE: %s  FE: %s\n\n' "${BE_HEALTH_URL}" "${FE_URL}"
}

cmd_preset() {
  local name="${1:-}"
  [[ -n "${name}" ]] || die "Usage: ./harness preset <local|hybrid|docker>"
  if [[ -f "${CONFIG_FILE}" ]]; then
    if grep -q '^PRESET=' "${CONFIG_FILE}"; then
      sed -i "s/^PRESET=.*/PRESET=${name}/" "${CONFIG_FILE}"
    else
      echo "PRESET=${name}" >>"${CONFIG_FILE}"
    fi
  else
    cp "${ROOT_DIR}/harness.config.example" "${CONFIG_FILE}"
    sed -i "s/^PRESET=.*/PRESET=${name}/" "${CONFIG_FILE}"
  fi
  log "Preset set to: ${name}"
}

cmd_fe() {
  local sub="${1:-}"
  load_config
  apply_preset
  case "${sub}" in
    start)   fe_start ;;
    stop)    fe_stop ;;
    restart) fe_stop; fe_start ;;
    install) fe_install ;;
    logs)    fe_logs ;;
    *) die "Usage: ./harness fe <start|stop|restart|install|logs>" ;;
  esac
}

cmd_be() {
  local sub="${1:-}"
  load_config
  apply_preset
  case "${sub}" in
    start)   be_start ;;
    stop)    be_stop ;;
    restart) be_stop; be_start ;;
    install) be_install ;;
    logs)    be_logs ;;
    *) die "Usage: ./harness be <start|stop|restart|install|logs>" ;;
  esac
}

usage() {
  cat <<EOF
Usage: ./harness <command> [options]

Commands:
  up                  Start BE + FE together (uses preset from harness.config)
  down                Stop all managed services
  restart             Restart BE + FE
  rebuild [be|fe|all] Reinstall dependencies and restart
  smoke               Run health/smoke checks against running stack
  status              Show service status
  preset <name>       Set preset: local | hybrid | docker
  fe <subcmd>         Frontend: start | stop | restart | install | logs
  be <subcmd>         Backend:  start | stop | restart | install | logs

Presets:
  local    Postgres in Docker; BE + FE run natively with hot-reload
  hybrid   Same as local (alias for native dev against Docker Postgres)
  docker   Full stack via docker compose up --build

Setup:
  cp harness.example harness && chmod +x harness
  cp harness.config.example harness.config
EOF
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

main() {
  local cmd="${1:-}"
  shift || true
  case "${cmd}" in
    up)       cmd_up "$@" ;;
    down)     cmd_down "$@" ;;
    restart)  cmd_restart "$@" ;;
    rebuild)  cmd_rebuild "$@" ;;
    smoke)    cmd_smoke "$@" ;;
    status)   cmd_status "$@" ;;
    preset)   cmd_preset "$@" ;;
    fe)       cmd_fe "$@" ;;
    be)       cmd_be "$@" ;;
    help|-h|--help|"") usage ;;
    *) die "Unknown command: ${cmd}. Run './harness help'." ;;
  esac
}

main "$@"
